{
    "name": "sr-website/sr-agent-markdown",
    "description": "WordPress plugin that serves Markdown representations of public pages for AI agents.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "league/html-to-markdown": "^5.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SRAgentMarkdown\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SRAgentMarkdown\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
